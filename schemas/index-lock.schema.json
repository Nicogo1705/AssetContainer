{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stride3d.net/asset-store/schemas/index-lock.schema.json",
  "title": "Stride Asset Store - Index Lock",
  "description": "Aggregate generated by CI (never hand-edited). The ONLY file the app consumes at startup.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "assets"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repo", "manifest", "latest", "validationStatus"],
        "properties": {
          "id": { "type": "string" },
          "repo": { "type": "string", "format": "uri" },
          "manifest": {
            "description": "Copy of AssetData/manifest.json resolved at the latest commit.",
            "type": "object"
          },
          "stars": {
            "type": ["integer", "null"],
            "description": "GitHub stargazer count, when known (filled by the bot via the GitHub API)."
          },
          "latest": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref", "commit", "contentHash"],
            "properties": {
              "ref": { "type": "string" },
              "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
              "contentHash": { "type": "string", "description": "Deterministic SHA-256 of the AssetData/ folder." },
              "detectedStrideVersion": { "type": ["string", "null"], "description": "Read from the .csproj (Stride.* PackageReference)." },
              "targetFramework": { "type": ["string", "null"], "description": "Target framework(s) read from the .csproj (e.g. net10.0)." },
              "externalDependencies": {
                "type": "array",
                "description": "NuGet packages the project references (external dependencies, not store assets).",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name"],
                  "properties": {
                    "name": { "type": "string" },
                    "version": { "type": ["string", "null"] }
                  }
                }
              },
              "resolvedDependencies": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Transitive set of resolved ids (deduplicated, cycle-free)."
              },
              "sizeBytes": { "type": "integer" }
            }
          },
          "versions": {
            "type": "array",
            "description": "Released versions discovered from the repo's git tags (author-controlled).",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["version", "tag", "commit"],
              "properties": {
                "version": { "type": "string" },
                "tag": { "type": "string" },
                "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
              }
            }
          },
          "certified": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["version", "commit"],
              "properties": {
                "version": { "type": "string" },
                "tag": { "type": "string" },
                "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
                "contentHash": { "type": "string" },
                "detectedStrideVersion": { "type": ["string", "null"] },
                "resolvedDependencies": { "type": "array", "items": { "type": "string" } },
                "certifiedBy": { "type": "string" },
                "certifiedAt": { "type": "string", "format": "date" }
              }
            }
          },
          "validationStatus": {
            "type": "string",
            "enum": ["ok", "warning", "error", "unavailable"]
          },
          "validationMessages": {
            "type": "array",
            "items": { "type": "string" }
          },
          "lastValidatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
